# Sepolia RPC endpoint (Alchemy or Infura)
RPC_ENDPOINT=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Database (matches docker-compose.yml defaults)
DB_NAME=squid-railgun-fiber-sepolia-v2
DB_HOST=localhost
DB_PORT=23798
DB_PASS=postgres

# Fiber Sepolia contract addresses
CHAIN_ID=11155111
RAILGUN_PROXY_CONTRACT_ADDRESS=0x4020Fd6030b62889F2094de97f5F7Abd6933987C
RAILGUN_PROXY_DEPLOYMENT_BLOCK=10387299
RAILGUN_POSEIDONT4_CONTRACT_ADDRESS=0xfeb4804930B2B9029a5bB1C50628098F5Cf08507

# Disable Subsquid Cloud RPC proxy (use RPC_ENDPOINT directly)
RAILGUN_RPC_TOGGLE=false
